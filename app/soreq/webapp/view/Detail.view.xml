<mvc:View
    controllerName="ust.so.soreq.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
>
    <Page
        id="_IDGenPage2"
        title="Sales Order Detail"
    >
        <headerContent>
            <Button
                id="_IDGenButton4"
                text="Edit"
                press="onEdit"
                visible="{= ${Status} !== 'OnHold' &amp;&amp; !${viewModel>/editMode} }"
            />
            <Button
                id="_IDGenButton8"
                icon="sap-icon://delete"
                type="Reject"
                visible="{= ${Status} === 'OnHold' 
    }"
                press="onDelete"
            />
            <Button
                id="_IDGenButtonApprove"
                text="Approve"
                type="Accept"
                press="onApprove"
                visible="{= ${Status} === 'OnHold' }"
            />

            <Button
                id="_IDGenButtonReject"
                text="Reject"
                type="Reject"
                press="onReject"
                visible="{=
        ${Status} !== 'Approved'
    }"
            />
            <Button
                id="_IDGenButton5"
                text="Save"
                type="Emphasized"
                press="onSave"
                visible="{viewModel>/editMode}"
            />
        </headerContent>

        <content>
            <VBox
                id="_IDGenVBox1"
                class="sapUiSmallMargin"
            >
                <Panel
                    id="_IDGenPanel"
                    headerText="Order Information"
                    width="100%"
                >
                    <HBox id="_IDGenHBox">
                        <VBox id="_IDGenVBox2">
                            <f:SimpleForm
                                id="_IDGenSimpleForm12"
                                editable="true"
                                layout="ResponsiveGridLayout"
                                columnsXL="3"
                                columnsL="3"
                                columnsM="2"
                            >
                                <f:content>
                                    <Label
                                        id="_IDGenLabel"
                                        width="200px"
                                        text="Customer ID"
                                    />
                                    <Input
                                        id="_IDGenInput7"
                                        width="200px"
                                        value="{CustomerId}"
                                        editable="{viewModel>/editMode}"
                                    />

                                    <Label
                                        id="_IDGenLabel1"
                                        text="Customer Name"
                                    />
                                    <Input
                                        id="_IDGenInput8"
                                        width="200px"
                                        value="{CustomerName}"
                                        editable="{viewModel>/editMode}"
                                    />

                                    <Label
                                        id="_IDGenLabel2"
                                        text="Factory"
                                    />
                                    <Input
                                        id="_IDGenInput9"
                                        width="200px"
                                        value="{Factory}"
                                        editable="{viewModel>/editMode}"
                                    />

                                    <Label
                                        id="_IDGenLabel3"
                                        text="Order Date"
                                    />
                                    <DatePicker
                                        id="_IDGenDatePicker2"
                                        width="200px"
                                        dateValue="{OrderDate}"
                                        editable="{viewModel>/editMode}"
                                        displayFormat="dd/MM/yyyy"
                                    />
                                </f:content>
                            </f:SimpleForm>
                        </VBox>
                        <f:SimpleForm
                            id="_IDGenSimpleForm"
                            editable="true"
                            layout="ResponsiveGridLayout"
                            columnsXL="3"
                            columnsL="3"
                            columnsM="2"
                        >
                            <f:content>
                                <Label
                                    id="_IDGenLabel4"
                                    text="Requested Date"
                                />
                                <DatePicker
                                    id="_IDGenDatePicker3"
                                    dateValue="{RequestedDate}"
                                    editable="{viewModel>/editMode}"
                                    displayFormat="dd/MM/yyyy"
                                />
                                <Label
                                    id="_IDGenLabel5"
                                    text="Currency"
                                    width="200px"
                                />
                                <Input
                                    id="_IDGenInput10"
                                    width="200px"
                                    value="{Currency}"
                                    editable="{viewModel>/editMode}"
                                />

                                <Label
                                    id="_IDGenLabel12"
                                    text="Total Amount"
                                    width="200px"
                                />
                                <Input
                                    id="_IDGenInput11"
                                    width="200px"
                                    value="{TotalAmount}"
                                    editable="{viewModel>/editMode}"
                                />

                                <Label
                                    id="_IDGenLabel13"
                                    text="Status"
                                    width="200px"
                                />
                                <Text
                                    id="_IDGenText14"
                                    width="200px"
                                    text="{Status}"
                                />
                            </f:content>
                        </f:SimpleForm>
                        <VBox id="_IDGenVBox3" />
                    </HBox>
                </Panel>
            </VBox>

            <Table
                id="_IDGenTable2"
                headerText="Items"
                items="{Items}"
            >
                <columns>
                    <Column id="_IDGenColumn">
                        <Text
                            id="_IDGenText15"
                            text="Item"
                        />
                    </Column>
                    <Column id="_IDGenColumn8">
                        <Text
                            id="_IDGenText16"
                            text="Material"
                        />
                    </Column>
                    <Column id="_IDGenColumn9">
                        <Text
                            id="_IDGenText17"
                            text="Description"
                        />
                    </Column>
                    <Column id="_IDGenColumn10">
                        <Text
                            id="_IDGenText18"
                            text="Qty"
                        />
                    </Column>
                    <Column id="_IDGenColumn11">
                        <Text
                            id="_IDGenText19"
                            text="Price"
                        />
                    </Column>
                    <Column id="_IDGenColumn12">
                        <Text
                            id="_IDGenText20"
                            text="Amount"
                        />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="_IDGenColumnListItem1">
                        <cells>
                            <Input
                                id="_IDGenInput12"
                                value="{ItemNo}"
                                editable="{viewModel>/editMode}"
                            />

                            <Input
                                id="_IDGenInput13"
                                value="{MaterialNo}"
                                editable="{viewModel>/editMode}"
                            />

                            <Input
                                id="_IDGenInput14"
                                value="{MaterialDescription}"
                                editable="{viewModel>/editMode}"
                            />

                            <Input
                                id="_IDGenInput15"
                                value="{Quantity}"
                                editable="{viewModel>/editMode}"
                            />

                            <Input
                                id="_IDGenInput16"
                                value="{UnitPrice}"
                                editable="{viewModel>/editMode}"
                            />

                            <Input
                                id="_IDGenInput17"
                                value="{NetAmount}"
                                editable="{viewModel>/editMode}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
